  },
  "featureFlows": {
    "states": {
      "base": {},
      "freeSpinIntro": {
        "cinematic": { "vfxPreset": "freeSpinIntroSweep", "animation": "introCine" }
      },
      "freeSpins": { "cinematic": { "vfxPreset": "freeSpinAmbient" } }
    },
    "transitions": [
      {
        "from": "base",
        "on": { "type": "freeSpinsAwarded" },
        "to": "freeSpinIntro"
      },
      {
        "from": "freeSpinIntro",
        "on": { "type": "freeSpinsAwarded" },
        "to": "freeSpins"
      }
    ],
    "entry": "base"
  },
  "tumble": {
    "explodeMs": 0,
    "dropMs": 0,
    "dropEasing": "linear",
    "refillStaggerMs": 0,
    "settleMs": 0,
    "stepGapMs": 0,
    "rollupCurve": "linear"
  }
