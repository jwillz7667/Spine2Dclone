{
  "name": "@marionette/format",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./effects": {
      "types": "./src/effects/index.ts",
      "import": "./src/effects/index.ts"
    },
    "./effects-types": {
      "types": "./src/effects/types.ts",
      "import": "./src/effects/types.ts"
    },
    "./slot": {
      "types": "./src/slot/index.ts",
      "import": "./src/slot/index.ts"
    },
    "./slot-types": {
      "types": "./src/slot/types.ts",
      "import": "./src/slot/types.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "gen:fixtures": "tsx scripts/gen-fixtures.mts",
    "gen:effects-fixtures": "tsx scripts/gen-effects-fixtures.mts",
    "gen:slot-fixtures": "tsx scripts/gen-slot-fixtures.mts"
  },
  "dependencies": {
    "@noble/hashes": "1.3.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
