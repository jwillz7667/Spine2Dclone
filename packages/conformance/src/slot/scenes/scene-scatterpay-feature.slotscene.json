{
  "grid": {
    "topology": "scatterPay",
    "cols": 6,
    "rows": 5,
    "cellWidth": 120,
    "cellHeight": 120,
    "cellGap": 6,
    "reelStopStaggerMs": 100,
    "gravity": "column-down",
    "anticipation": {
      "triggerSymbols": ["scatter"],
      "thresholdCount": 2,
      "maxAnticipatingCols": 2
    }
  },
  "symbols": {},
  "winSequencer": {
    "sequences": {
      "default": { "steps": [] }
    },
    "thresholds": { "big": 20, "mega": 50, "epic": 100 },
